import "../system/window"
import "../scene/camera"

namespace rmmr
  namespace controller

    // Optional input controller for an existing scene::Camera feature.
    attribute Camera of scene::Camera
      one
        yaw_rad: float
        pitch_rad: float
        fps_initialized: bool
        >create()-> #
        =update() // RMB + mouse: rotate anchored scene::Camera node (HPB); input via system::Window on Device
