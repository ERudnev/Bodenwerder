namespace rmmr
  namespace system

    entity Core
      struct GLVer
        major: integer
        minor: integer
      one
        assets_root: string
        version: GLVer

    // tricky Aspect: its Quantum is a root with a role of "owner of everything", all Actions are "all"(static)
    entity Device
      using Handle @external(OpenGL window C++ pointer aka "GLFWwindow")
      one
        core: anchor<Core>
        handle: Handle
        !release(-one)
      all
        ?poll_events(~)
