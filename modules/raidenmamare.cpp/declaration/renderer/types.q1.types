import "../math"
import "../resources_old/geometry"
import "../resources_old/material"
import "gl"

namespace rmmr
  namespace renderer

    using InstanceBuffer as ~resource_old::Geometry::VertexBuffer

    enum Pass : opaque, transparent, shadow, ui, gizmo

    struct RenderState

    struct InstanceSource
      buffer: InstanceBuffer
      byte_offset: IntPtr

    struct Command
      pass: Pass
      model: mat4
      geometry: #resource_old::Geometry
      material: #resource_old::Material
      albedo: RGB
      opacity: float
      instance_data: InstanceSource
      instance_count: Count
      render_state: RenderState

    using CommandBuffer as vector<Command>
