import "node"

namespace rmmr
  namespace scene

    feature Grid of Node
      one
        geometry: #resource::Geometry
        material: #resource::Material
        opacity: float
        ?submit(>where: renderer::CommandBuffer)
      all
        >create(Pos, HPB, one) -> #
