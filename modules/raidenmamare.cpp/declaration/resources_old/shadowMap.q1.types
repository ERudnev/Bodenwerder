import "../system/core"

namespace rmmr
  namespace resource_old

    entity ShadowMap
      using Framebuffer as @external(OpenGL framebuffer handle)
      using DepthTexture as @external(OpenGL depth texture handle)
      one
        fbo: Framebuffer
        depth: DepthTexture
        size: index2
        >create(#Device, size: index2)->#
        ?bind()
        ?clear()
        ?unbind()

    group<ShadowMap> of Device
