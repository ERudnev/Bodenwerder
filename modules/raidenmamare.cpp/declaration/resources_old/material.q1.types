import "../assets/shader"
import "../system/core"
import "texture"

namespace rmmr
  namespace resource_old

    entity Material
      struct TextureBinding
        id: Uniform::Id
        texture: #Texture
      using Locations as @external(rmmr::material::Semantics::RuntimeMapping)
      one
        shader: #Shader
        locations: Locations
        bindings: vector<Uniform::Binding>
        textures: vector<TextureBinding>
        ?apply(#Device)

    group<Material> of Device
