import "system/core"

namespace rmmr
  namespace resource

  // persistent layer
    component Manager of system::Core
      one
        location: filepath

    // persistent thing
    entity Unit
      using Name as string
      struct Reference
        id: #
        backup: Name
      one
        manager: #Manager
        name: Name
        library: string
        ?remember()->Reference

    group<Unit> of Manager
