import "scene/node"
import "primitives/base"
import "materials/core"
import "math"

namespace rmmr
  namespace scene

    attribute PrimitiveActor of Node
      element
        geometry: #primitive::Base
        material: #material::Core
        albedo: RGB
      table
        +create(Pos, HPB, geometry: #primitive::Base, material: #material::Core, albedo: RGB)
