import "scene/node"
import "scene/camera"
import "scene/light"

namespace rmmr
  namespace scene

    entity Core
      one
        ambient: RGB
        ambient_intensity: float

    group<Node> of Core
    group<Camera> of Core
    group<Light> of Core

    manipulation Interface of Core
      >createScene()->#
      >createRawNode(#, Locator)->#Node
      >createCamera(#, Locator, one<Camera>)->#Camera
      >createLight(#, Locator, one<Light>)->#Light
