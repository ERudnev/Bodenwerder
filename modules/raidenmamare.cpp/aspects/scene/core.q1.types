import "scene/node"
import "scene/camera"
import "scene/light"

namespace rmmr
  namespace scene

    entity Core
      ambient: RGB
      ambient_intensity: float

    group<Node> of Core
    group<Camera> of Core
    group<Light> of Core

    archetype Interface
      >createScene()->#Core
      >createRawNode(#Core, one<Node>)->#Node
      >createCamera(#Core, one<Node>, one<Camera>)->#Camera
      >createLight(#Core, one<Node>, one<Light>)->#Light
