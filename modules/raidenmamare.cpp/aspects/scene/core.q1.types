import "scene/node"
import "scene/camera"
import "scene/light"

namespace rmmr
  namespace scene

    entity Core
      one
        ambient: RGB
        ambient_intensity: float

    group<Node> of Core
    group<Camera> of Core
    group<Light> of Core

    archetype Interface
      >createScene()->#Core
      >createRawNode(#Core, Locator)->#Node
      >createCamera(#Core, Locator, one<Camera>)->#Camera
      >createLight(#Core, Locator, one<Light>)->#Light
