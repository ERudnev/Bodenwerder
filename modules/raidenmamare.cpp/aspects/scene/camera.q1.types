import "scene/node"
import "math"

namespace rmmr
  namespace scene

    // Camera settings bound to a scene node.
    attribute Camera of Node
      one
        fov_y: float
        z_near: float
        z_far: float
        ?projection(aspect_ratio: float) -> mat4
        ?view() -> mat4
        ?view_projection(aspect_ratio: float) -> mat4
      all
        >create(Locator, fov_y: float, z_near: float, z_far: float) -> #
