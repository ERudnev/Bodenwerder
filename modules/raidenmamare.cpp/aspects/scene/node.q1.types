import "math"

namespace rmmr
  namespace scene

    // Basic transformable scene node.
    // Rendering payloads (primitive, camera, light, viewport bindings) can be layered later.
    entity Node
      element
        position: Pos
        rotation: quat
        ?transform(): mat4
        ?hpb(): HPB // heading/pitch/bank (degrees)
        *hpb(HPB)
      table
        +posHpb(pos: Pos, hpb: HPB) // convenience c-tor
