namespace rmmr

  entity Application
    all
      assets_root: string
      context_major: integer
      context_minor: integer
      ?poll_events(~)

  entity Window
    using Handle @external(OpenGL window C++ pointer aka "GLFWwindow")
    one
      title: string
      size: index2
      handle: Handle
      ?present()
      !release(-one)

  archetype Device
    >start()
    >openWindow(~Window::title, ~Window::size)->#Window
    >shutdown()
