namespace rmmr

  // Root OpenGL window/context resource for the demo application.
  resource Core @external(opengl_window)
    passport
      assets_root: string
      title: string
      size: index2
      context_major: integer
      context_minor: integer
    element
      ?provide()->opengl_window
      ?present()
      ?poll_events()
      ?materialize()
      ?release()