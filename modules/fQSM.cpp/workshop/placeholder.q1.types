namespace placeholder

  entity Person
    one
      name: string
      age: integer

  entity Family
    struct Parents
      dad: #Person
      mom: #Person
    one
      lastname: string
      parents: Parents
      children: vector<#Person>
    all
      sharedMoney: integer

  archetype Registry
    >createSixFamilies()
      // six families; children counts cover 0..4 (corners)
