namespace placeholder

  entity Minimal

  attribute MyAttribute of Minimal
    always
      recommendedUpdateSize: integer = 2
    one
      x: integer
      y: integer
      // all "one" reactions may listen only own aspect updates?
      !ruleOne(-one) // reacts on deletion
      !ruleTwo(=one) // reacts on change (Quantum constraint)
    all
      !localRule(~) // ('~' mrans "type of"own type MyAttribute is iplicit argument
      !globalRule(~Minimal) // including implicit MyAttribute
