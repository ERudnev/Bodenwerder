namespace community

  entity UselessItem
    one
      reallyUseless: bool

  entity Person
    one
      name: string
      age: integer
      cache: as @external(some ugly C++ shared_ptr<std::string> as example of non-serializable field)
    all
      >generate(age: integer)-># // name is random (can use pre-generated table)
      >one_year_passed() // run all persond age++

  group<UselessItem> of Person

  entity Family
    struct Parents
      dad: #Person?
      mom: #Person?
    one
      lastname: string
      parents: Parents
      children: vector<#Person>
    all
      sharedMoney: integer
      legends: vector<string>
      >generate(dad: bool, mom: bool, children: integer)->#

  archetype Registry
    >createSixFamilies()
    >grantPersonSomethingUseless(#Person, meaninglessValue: ~UselessItem::reallyUseless) // assigns new UselessItem to Person's UselessItem group
      // six families; children counts cover 0..4 (corners)
