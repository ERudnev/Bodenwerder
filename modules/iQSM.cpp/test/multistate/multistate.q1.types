namespace RnD

  namespace Logic
    entity House
      element
        happiness: integer
    
    entity Pairing
      element
        participants: pair<#House> @anchor(all)
        *update() // makes both targeted houses one step closer one to another: [10, 20] -> [11, 19]


  namespace View
    component HappyHouse of Logic::House
      element
        previous_happiness: ~Logic::House::happiness

        ?interpolated_happiness()->float // evaluated average between prev and current
        *update()

