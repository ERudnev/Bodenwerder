{
  "files.associations": {
    "*.q1.types": "q1"
  },
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": true,
  "cmake.defaultConfigurePreset": "ninja-clang-debug",
  "cmake.defaultBuildPreset": "debug",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "variable.parameter.q1",
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  }
}
