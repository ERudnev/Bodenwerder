{
  "name": "Q1",
  "scopeName": "source.q1",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#directives" },
    { "include": "#operations" },
    { "include": "#operationReturn" },
    { "include": "#typeExpressionMarkers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.q1", "match": "//.*$" }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.q1",
          "match": "^\\s*(import)\\s+(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.control.import.q1" },
            "2": { "name": "string.quoted.import.q1" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.q1",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.q1", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.single.q1",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.q1", "match": "\\\\." }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.q1", "match": "\\b\\d+(\\.\\d+)?\\b" }
      ]
    },
    "directives": {
      "patterns": [
        { "name": "keyword.other.directive.q1", "match": "@\\w+(\\([^)]*\\))?" }
      ]
    },
    "operations": {
      "patterns": [
        {
          "name": "meta.operation.signature.q1",
          "begin": "^(\\s*)([\\?\\=>!])\\s*([A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*)\\s*\\(",
          "beginCaptures": {
            "2": { "name": "keyword.other.q1.operation-prefix" },
            "3": { "name": "entity.name.function.q1" }
          },
          "end": "\\)",
          "patterns": [
            {
              "name": "variable.parameter.q1",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*:)"
            },
            { "include": "#typeExpressionMarkers" },
            { "include": "#types" },
            { "include": "#operators" },
            { "include": "#numbers" },
            { "include": "#strings" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.q1",
          "match": "\\b(namespace|declare|type|template|struct|as|enum|entity|attribute|component|agent|depends|static|element|table|model|passport)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.q1",
          "match": "\\b(integer|index2|float|string|boolean|seconds|time|mat4|vec3|quat|vector|map|set|umap|uset)\\b"
        },
        { "name": "entity.name.type.q1", "match": "\\b[A-Z][A-Za-z0-9_]*\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.q1", "match": "(::|~|:|\\=|>|<|!)" }
      ]
    },
    "typeExpressionMarkers": {
      "patterns": [
        {
          "match": "(#)(\\?)(?=\\s*(?:$|//|,|\\)|\\]|>|<|@|;))",
          "captures": {
            "1": { "name": "keyword.other.q1.type-id-hash" },
            "2": { "name": "keyword.other.q1.type-optional-suffix" }
          }
        },
        {
          "match": "(#)([A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*)\\b",
          "captures": {
            "1": { "name": "keyword.other.q1.type-id-hash" },
            "2": { "name": "entity.name.type.q1" }
          }
        },
        {
          "match": "(#)(?=\\s*(?:$|//|,|\\)|\\]|>|<|@|;))",
          "captures": {
            "1": { "name": "keyword.other.q1.type-id-hash" }
          }
        },
        {
          "match": "(?<=[A-Za-z0-9_#\\)\\]>])\\?(?=\\s*(?:$|//|,|\\)|\\]|>|<|@|;|\\{))",
          "name": "keyword.other.q1.type-optional-suffix"
        }
      ]
    },
    "operationReturn": {
      "patterns": [
        {
          "name": "meta.operation.return.q1",
          "match": "(?<=\\))\\s*(:)\\s*([^\\n]+?)(?=//|$)",
          "captures": {
            "1": { "name": "keyword.operator.q1" },
            "2": {
              "patterns": [
                { "include": "#typeExpressionMarkers" },
                { "include": "#types" },
                { "include": "#numbers" },
                { "include": "#operators" }
              ]
            }
          }
        }
      ]
    }
  }
}
