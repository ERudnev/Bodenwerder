{
  "name": "Q1",
  "scopeName": "source.q1",
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#directives" },
    { "include": "#operations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.q1", "match": "//.*$" }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.q1",
          "match": "^\\s*(#\\s*include)\\s+(\"[^\"]*\"|<[^>\\n]+>)",
          "captures": {
            "1": { "name": "keyword.control.import.include.q1" },
            "2": { "name": "string.quoted.include.q1" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.q1",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.q1", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.single.q1",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.q1", "match": "\\\\." }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.q1", "match": "\\b\\d+(\\.\\d+)?\\b" }
      ]
    },
    "directives": {
      "patterns": [
        { "name": "keyword.other.directive.q1", "match": "@\\w+(\\([^)]*\\))?" }
      ]
    },
    "operations": {
      "patterns": [
        {
          "name": "meta.operation.signature.q1",
          "begin": "^(\\s*)([\\?\\*\\+!])\\s*([A-Za-z_][A-Za-z0-9_]*(?:::[A-Za-z_][A-Za-z0-9_]*)*)\\s*\\(",
          "beginCaptures": {
            "2": { "name": "keyword.operator.q1" },
            "3": { "name": "entity.name.function.q1" }
          },
          "end": "\\)",
          "patterns": [
            {
              "name": "variable.parameter.q1",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*:)"
            },
            { "include": "#types" },
            { "include": "#operators" },
            { "include": "#numbers" },
            { "include": "#strings" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.q1",
          "match": "\\b(namespace|declare|type|template|struct|as|enum|entity|attribute|component|resource|depends|static|element|table|model|passport)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.q1",
          "match": "\\b(integer|index2|float|string|boolean|seconds|time|mat4|vec3|quat|vector|map|set|umap|uset)\\b"
        },
        { "name": "entity.name.type.q1", "match": "\\b[A-Z][A-Za-z0-9_]*\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.q1", "match": "(::|->|~|:|\\?|\\*|\\+|!|#)" }
      ]
    }
  }
}
